{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    /* Output Configuration */
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,

    /* Types Generation */
    "declaration": true,
    "declarationMap": true,

    /* Strictness & Safety */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* Interop & Parsing */
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}